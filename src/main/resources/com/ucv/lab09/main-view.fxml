<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ucv.lab09.controller.MainController"
            prefWidth="530" prefHeight="450">

    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">

            <Tab text="Estudiante Pregrado">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                    <GridPane hgap="10" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints prefWidth="150"/>
                        </columnConstraints>

                        <Label text="Nombres"            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="Apellidos"          GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Semestre Ingreso"   GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                        <TextField fx:id="txtNombresPre"   GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <TextField fx:id="txtApellidosPre" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <ComboBox  fx:id="cmbSemestrePre"  GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity"/>
                    </GridPane>

                    <GridPane hgap="10" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="140"/>
                            <ColumnConstraints prefWidth="160"/>
                            <ColumnConstraints prefWidth="150"/>
                        </columnConstraints>

                        <Label text="Categoría (A/B)"       GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="Procedencia Colegio"   GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Promedio Ponderado"    GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                        <ComboBox  fx:id="cmbCategoriaPre"   GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <ComboBox  fx:id="cmbProcedenciaPre" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <TextField fx:id="txtPromedioPre"     GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity"/>
                    </GridPane>

                    <TextArea fx:id="txtAreaPre"
                              prefHeight="170"
                              editable="false"
                              wrapText="true"
                              VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Registrar Estudiante" onAction="#onRegistrarPregrado"   prefWidth="160"/>
                        <Button text="Borrar"               onAction="#onBorrarPregrado"      prefWidth="100"/>
                        <Button text="Salir"                onAction="#onSalir"               prefWidth="100"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab text="Estudiante Postgrado">
                <VBox spacing="10">
                    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

                    <GridPane hgap="10" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints prefWidth="150"/>
                            <ColumnConstraints prefWidth="150"/>
                        </columnConstraints>

                        <Label text="Nombres"            GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label text="Apellidos"          GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="Semestre Ingreso"   GridPane.columnIndex="2" GridPane.rowIndex="0"/>

                        <TextField fx:id="txtNombresPos"   GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <TextField fx:id="txtApellidosPos" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="Infinity"/>
                        <ComboBox  fx:id="cmbSemestrePos"  GridPane.columnIndex="2" GridPane.rowIndex="1" maxWidth="Infinity"/>
                    </GridPane>

                    <GridPane hgap="10" vgap="4">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="200"/>
                        </columnConstraints>

                        <Label text="Grado Académico" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="cmbGradoPos" GridPane.columnIndex="0" GridPane.rowIndex="1" maxWidth="Infinity"/>
                    </GridPane>

                    <TextArea fx:id="txtAreaPos"
                              prefHeight="170"
                              editable="false"
                              wrapText="true"
                              VBox.vgrow="ALWAYS"/>

                    <HBox spacing="10" alignment="CENTER">
                        <Button text="Registrar Estudiante" onAction="#onRegistrarPostgrado"  prefWidth="160"/>
                        <Button text="Borrar"               onAction="#onBorrarPostgrado"     prefWidth="100"/>
                        <Button text="Salir"                onAction="#onSalir"               prefWidth="100"/>
                    </HBox>
                </VBox>
            </Tab>

        </TabPane>
    </center>
</BorderPane>